# ============================================================
# .env.example — Variables de entorno requeridas
# ISO 27001 A.12.1 — Copiar como .env.dev y completar valores
# NUNCA commitear el .env real con secretos al repositorio
# ============================================================

# === Django Core ===
# Modo debug: True solo en desarrollo
DJANGO_DEBUG=True

# Clave secreta: mínimo 50 caracteres aleatorios
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CAMBIAR-POR-CLAVE-SEGURA-MINIMO-50-CARACTERES

# Módulo de settings activo
DJANGO_SETTINGS_MODULE=config.settings.dev

# Hosts permitidos (separados por coma)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Idioma y zona horaria
DJANGO_LANGUAGE_CODE=es-ec
DJANGO_TIME_ZONE=America/Guayaquil

# === MongoDB ===
# Nombre de la base de datos
MONGO_DB_NAME=inventory_dev

# URI de conexión completa (preferida para Docker Compose):
# formato: mongodb://host:port/dbname
MONGO_DB_HOST=mongodb://localhost:27017/inventory_dev

# Variables individuales (alternativa sin Docker):
MONGO_HOST=localhost
MONGO_PORT=27017

# === CORS ===
# Orígenes permitidos (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# === Logging ===
# Nivel de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
